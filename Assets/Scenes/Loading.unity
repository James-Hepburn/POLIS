--- !u!114 &252830069
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 252830067}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e939807b669dc4e7f8275d4d57f9837f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPC
  npcName: Nikias
  relationshipGain: 5
  dialogueLow: I have nothing to say to you. Do not waste my time.
  dialogueNeutral: Hmm. You are new to the Agora. I am Nikias. Work hard and perhaps
    we will speak again.
  dialogueFriendly: Ah, good to see you. Your reputation in the market grows. Keep
    at it.
  dialogueClose: You have proven yourself, my friend. Athens is better for men like
    you.
  dialogueFestivalGeneric: The city breathes differently on days like this. Even
    commerce feels sacred.
  dialogueCityDionysia: 
  dialogueThargelia: 
  dialoguePanathenaia: Athena's festival brings the best traders to Athens. I have
    already made three deals this morning.
  dialogueHephaestia: 
  dialogueThesmophoria: 
  dialoguePyanopsia: 
  dialogueLenaia: 
  dialogueHaloa: 
  interactionRadius: 0.5
  timeCostMinutes: 30
  conversationCooldownSeconds: 10
  promptUI: {fileID: 672591889}
  romancePromptUI: {fileID: 509073372}
  loanPromptUI: {fileID: 0}
