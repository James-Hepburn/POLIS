--- !u!114 &2109490519
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2109490517}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e939807b669dc4e7f8275d4d57f9837f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPC
  npcName: Demetrios
  relationshipGain: 5
  dialogueLow: You dishonour yourself. Do not speak to me.
  dialogueNeutral: You want to be a soldier? Then train. Words mean nothing here.
    Sweat does.
  dialogueFriendly: You're tougher than I expected. Keep pushing.
  dialogueClose: I've fought beside men half as capable as you. Athens is lucky to
    have you.
  dialogueFestivalGeneric: A soldier respects the festivals. The gods deserve their
    due.
  dialogueCityDionysia: 
  dialogueThargelia: 
  dialoguePanathenaia: "The procession up the Acropolis \u2014 I marched in it for
    the first time as a recruit. I still feel it in my chest."
  dialogueHephaestia: 
  dialogueThesmophoria: 
  dialoguePyanopsia: 
  dialogueLenaia: 
  dialogueHaloa: 
  interactionRadius: 0.5
  timeCostMinutes: 30
  conversationCooldownSeconds: 10
  promptUI: {fileID: 719509747}
  romancePromptUI: {fileID: 0}
