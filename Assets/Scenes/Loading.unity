  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e939807b669dc4e7f8275d4d57f9837f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPC
  npcName: Chloe
  relationshipGain: 5
  dialogueLow: I think you should go.
  dialogueNeutral: Hello. Father is busy in the workshop if you are looking for him.
  dialogueFriendly: You are easier to talk to than most men who come through here.
    That is not nothing.
  dialogueClose: I made extra bread this morning. I do not know why I thought of
    you when I did.
  dialogueFestivalGeneric: Father closes the workshop on festival days. It is the
    only time he truly rests.
  dialogueCityDionysia: I saw the performance three times. Each time something different
    moved me.
  dialogueThargelia: 
  dialoguePanathenaia: 
  dialogueHephaestia: 
  dialogueThesmophoria: 
  dialoguePyanopsia: 
  dialogueLenaia: 
  dialogueHaloa: Tonight the rules are different. I like that. Just for one night.
  interactionRadius: 0.5
  timeCostMinutes: 30
  conversationCooldownSeconds: 10
  promptUI: {fileID: 1469662888}
  romancePromptUI: {fileID: 84848251}
  loanPromptUI: {fileID: 0}
