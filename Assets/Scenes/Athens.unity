--- !u!114 &382418065
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 382418064}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e939807b669dc4e7f8275d4d57f9837f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPC
  npcName: Miriam
  relationshipGain: 5
  dialogueLow: "In Alexandria we have a saying \u2014 a closed hand receives nothing.
    You would do well to remember it."
  dialogueNeutral: I have traded in six cities. Athens is the most interesting and
    the most exhausting. Sometimes on the same afternoon.
  dialogueFriendly: You are one of the few here who does not look at me like I arrived
    on the wrong ship. I appreciate that more than you know.
  dialogueClose: I have something set aside for you. Came off a ship from Carthage
    last week. I do not show it to everyone.
  interactionRadius: 1.5
  timeCostMinutes: 30
  conversationCooldownSeconds: 10
  promptUI: {fileID: 1437971847}
  dialogueUI: {fileID: 1257590747}
  dialogueText: {fileID: 1059623964}
  npcNameText: {fileID: 551942537}
