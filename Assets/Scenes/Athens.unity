  m_Script: {fileID: 11500000, guid: e939807b669dc4e7f8275d4d57f9837f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPC
  npcName: Lydia
  relationshipGain: 5
  dialogueLow: Please, I have nothing to say to you.
  dialogueNeutral: Good day. My father speaks well of men who apply themselves to
    their work.
  dialogueFriendly: You always seem to find me in the Agora. I confess I have stopped
    minding.
  dialogueClose: I told my father I met you again today. He said nothing. But he
    smiled.
  interactionRadius: 1.5
  timeCostMinutes: 30
  conversationCooldownSeconds: 10
  promptUI: {fileID: 799177711}
  dialogueUI: {fileID: 354177099}
  dialogueText: {fileID: 2052171175}
  npcNameText: {fileID: 1970754219}
