--- !u!114 &722323115
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 722323114}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e939807b669dc4e7f8275d4d57f9837f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPC
  npcName: Kallias
  relationshipGain: 5
  dialogueLow: I would choose your next words carefully. I have a long memory and
    a longer reach.
  dialogueNeutral: Everything in this city moves through the Agora. And everything
    in the Agora moves through me.
  dialogueFriendly: You are not as foolish as you look. That is a compliment, in
    case you were wondering.
  dialogueClose: I will tell you something I tell very few people. The city rewards
    those who know which doors to knock on. Knock on mine.
  interactionRadius: 1.5
  timeCostMinutes: 30
  conversationCooldownSeconds: 10
  promptUI: {fileID: 2043160587}
  dialogueUI: {fileID: 1219311975}
  dialogueText: {fileID: 1885953636}
  npcNameText: {fileID: 1069852894}
