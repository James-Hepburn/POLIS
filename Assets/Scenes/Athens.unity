  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e939807b669dc4e7f8275d4d57f9837f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPC
  npcName: Xanthos
  relationshipGain: 5
  dialogueLow: I have no time for men who cannot keep up.
  dialogueNeutral: The Panathenaia is closer than people think. I am ready. The question
    is whether Athens is ready to watch.
  dialogueFriendly: You have something about you. Not strength exactly. Determination,
    maybe. I respect that more than strength anyway.
  dialogueClose: You are the kind of person I would want beside me if things went
    badly. That is the highest thing I know how to say.
  interactionRadius: 1.5
  timeCostMinutes: 30
  conversationCooldownSeconds: 10
  promptUI: {fileID: 740533624}
  dialogueUI: {fileID: 1329137546}
  dialogueText: {fileID: 377532998}
  npcNameText: {fileID: 2016270333}
