  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPC
  npcName: Eudoros
  relationshipGain: 5
  dialogueLow: The gods see what you have done. I suggest you reflect carefully.
  dialogueNeutral: I am Eudoros, servant of Zeus. The gods watch all who walk this
    city. Remember that.
  dialogueFriendly: "Your piety does not go unnoticed \u2014 by me or by the gods."
  dialogueClose: In all my years serving Zeus, few have shown the devotion you have.
    You honour Athens.
  interactionRadius: 1.5
  timeCostMinutes: 30
  conversationCooldownSeconds: 10
  promptUI: {fileID: 450490350}
  dialogueUI: {fileID: 796004739}
  dialogueText: {fileID: 299016358}
  npcNameText: {fileID: 1442521098}
