  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e939807b669dc4e7f8275d4d57f9837f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPC
  npcName: Theron
  relationshipGain: 5
  dialogueLow: Your thinking is muddled. Come back when you have something worth
    saying.
  dialogueNeutral: "Ah, a new face. I am Theron. Tell me \u2014 what do you believe
    justice truly is?"
  dialogueFriendly: You argue well. I don't agree with you, but you make me think.
    That's rare.
  dialogueClose: I used to think I was the sharpest mind in Athens. You're making
    me reconsider.
  interactionRadius: 1.5
  timeCostMinutes: 30
  conversationCooldownSeconds: 10
  promptUI: {fileID: 36608356}
  dialogueUI: {fileID: 2075146348}
  dialogueText: {fileID: 1753212585}
  npcNameText: {fileID: 1909897067}
